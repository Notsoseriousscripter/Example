RunService.RenderStepped:Connect(function()
    --------------------------------------------------
    -- FOV
    --------------------------------------------------
    if Settings.ShowFOV then
        circle.Visible = true
        circle.Position = GetCursor()
        circle.Radius = Settings.FOV
    else
        circle.Visible = false
    end

    --------------------------------------------------
    -- AIMBOT (SMOOTH LOCK)
    --------------------------------------------------
    if Settings.Enabled then
        local target = GetNearest()
        LockedTarget = target

        if target then
            local camPos = Camera.CFrame.Position
            local aimCF = CFrame.new(camPos, target.Position)

            -- smooth lerp (prevents snapping/kick flags)
            Camera.CFrame = Camera.CFrame:Lerp(aimCF, 0.25)
        end
    else
        LockedTarget = nil
    end

    --------------------------------------------------
    -- ESP UPDATE
    --------------------------------------------------
    for plr, box in pairs(ESP) do
        if not Settings.ESPEnabled or not IsEnemy(plr) then
            box.Visible = false
            continue
        end

        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if not hrp or not hum or hum.Health <= 0 then
            box.Visible = false
            continue
        end

        local pos, visible = Camera:WorldToViewportPoint(hrp.Position)

        if visible then
            local size = 2600 / pos.Z
            box.Size = Vector2.new(size, size * 1.4)
            box.Position = Vector2.new(pos.X - size/2, pos.Y - size/1.2)
            box.Visible = true
        else
            box.Visible = false
        end
    end
end)

