local function IsEldian()
    return LocalPlayer.Team and LocalPlayer.Team.Name == "Eldian"
end

local function GetCharacterModel(plr)
    local obj = workspace:FindFirstChild("Objects")
    local chars = obj and obj:FindFirstChild("Characters")
    return chars and chars:FindFirstChild(plr.Name)
end

local function GetNape(plr)
    local char = GetCharacterModel(plr)
    if not char then return end

    for _,v in pairs(char:GetChildren()) do
        if v:FindFirstChild("Nape") then
            return v.Nape
        end
    end
end

-- 🔥 NEW: GET ALL TENDONS
local function GetTendons(plr)
    local tendons = {}
    local char = GetCharacterModel(plr)
    if not char then return tendons end

    for _,v in pairs(char:GetDescendants()) do
        if string.find(v.Name:lower(),"tendon") then
            table.insert(tendons,v)
        end
    end

    return tendons
end

local function HasTool(plr)
    local char = plr.Character
    if not char then return false end
    for _,v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then
            return true
        end
    end
    return false
end

